{
  "compilerOptions": {
    "composite": true,
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "rootDir": "./generated-src",
    "outDir": "./generated",
    "noEmit": false,
    "erasableSyntaxOnly": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.generated.tsbuildinfo"
  },
  "include": [
    "generated-src"
  ]
}
